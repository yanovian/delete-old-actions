{
  "name": "prune-old-actions",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "postbuild": "terser dist/index.js --output dist/index.js --compress --mangle",
    "clean": "tsc --build --clean && rm -rf dist/*",
    "test": "jest",
    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.16.5",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "terser": "^5.43.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "packageManager": "pnpm@11.13.0"
}
